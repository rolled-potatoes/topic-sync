{
  "name": "@rolled-potatoes/kafka-registry-sync",
  "version": "0.5.0",
  "description": "Kafka topic and schema registry sync toolkit",
  "license": "UNLICENSED",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/rolled-potatoes/topic-sync.git"
  },
  "homepage": "https://github.com/rolled-potatoes/topic-sync#readme",
  "bugs": {
    "url": "https://github.com/rolled-potatoes/topic-sync/issues"
  },
  "type": "module",
  "main": "./dist/index.cjs",
  "module": "./dist/index.mjs",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.mjs",
      "require": "./dist/index.cjs"
    }
  },
  "bin": {
    "krsync": "dist/cli.cjs"
  },
  "files": [
    "dist"
  ],
  "publishConfig": {
    "registry": "https://npm.pkg.github.com"
  },
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch",
    "typecheck": "tsc --noEmit",
    "prepublishOnly": "npm run build && npm run typecheck",
    "publish:github": "npm publish",
    "release": "semantic-release",
    "release:dry-run": "semantic-release --dry-run",
    "prepare": "husky"
  },
  "dependencies": {
    "commander": "^12.1.0",
    "jiti": "^2.4.2",
    "kafkajs": "^2.2.4",
    "zod": "^3.24.4"
  },
  "devDependencies": {
    "@commitlint/cli": "^20.5.3",
    "@commitlint/config-conventional": "^20.5.3",
    "@semantic-release/commit-analyzer": "^13.0.1",
    "@semantic-release/git": "^10.0.1",
    "@semantic-release/github": "^11.0.6",
    "@semantic-release/npm": "^12.0.2",
    "@semantic-release/release-notes-generator": "^14.1.0",
    "@types/node": "^22.15.0",
    "conventional-changelog-conventionalcommits": "^9.3.1",
    "husky": "^9.1.7",
    "semantic-release": "^24.2.5",
    "tsup": "^8.5.0",
    "typescript": "^5.8.3"
  }
}
