{
  "name": "@rolled-potatoes/kafka-registry-sync",
  "version": "0.2.0",
  "description": "Kafka topic and schema registry sync toolkit",
  "license": "UNLICENSED",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/rolled-potatoes/topic-sync.git"
  },
  "homepage": "https://github.com/rolled-potatoes/topic-sync#readme",
  "bugs": {
    "url": "https://github.com/rolled-potatoes/topic-sync/issues"
  },
  "type": "module",
  "main": "./dist/index.cjs",
  "module": "./dist/index.mjs",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.mjs",
      "require": "./dist/index.cjs"
    }
  },
  "bin": {
    "krsync": "dist/cli.cjs"
  },
  "files": [
    "dist"
  ],
  "publishConfig": {
    "registry": "https://npm.pkg.github.com"
  },
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch",
    "typecheck": "tsc --noEmit",
    "prepublishOnly": "npm run build && npm run typecheck",
    "publish:github": "npm publish"
  },
  "dependencies": {
    "commander": "^12.1.0",
    "jiti": "^2.4.2",
    "kafkajs": "^2.2.4",
    "zod": "^3.24.4"
  },
  "devDependencies": {
    "@types/node": "^22.15.0",
    "tsup": "^8.5.0",
    "typescript": "^5.8.3"
  }
}
